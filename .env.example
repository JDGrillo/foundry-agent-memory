# Azure AI Foundry project endpoint
# Format: https://<resource>.services.ai.azure.com/api/projects/<project-id>
FOUNDRY_PROJECT_ENDPOINT=

# Chat model deployment name (e.g., gpt-4o, gpt-5.2)
CHAT_MODEL_DEPLOYMENT=gpt-4o

# Embedding model deployment name (required for memory stores)
EMBEDDING_MODEL_DEPLOYMENT=text-embedding-3-small
